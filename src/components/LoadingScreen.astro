---
const words = ['Ciao', 'Bonjour', 'स्वागत', 'Hello', 'Olá', 'おい', 'Hallå', 'Guten Tag', 'Hallo'];
---

<div class="loading-container">
  <div class="loading-screen">

    <!-- Blobs di sfondo animati -->
    <div class="ls-blob ls-blob-1"></div>
    <div class="ls-blob ls-blob-2"></div>
    <div class="ls-blob ls-blob-3"></div>

    <!-- Griglia di punti sottile -->
    <div class="ls-grid"></div>

    <!-- Parole al centro -->
    <div class="loading-words">
      {words.map((word, i) => (
        <h2 class:list={[
          'home-active',
          { 'home-active-first': i === 0 },
          { 'home-active-last': i === words.length - 1 },
          { 'jap': word === 'おい' }
        ]}>
          {word}<div class="dot"></div>
        </h2>
      ))}
    </div>

    <!-- Footer con contatore e barra progresso -->
    <div class="ls-footer">
      <span class="ls-name">Gianluca Zaccarelli</span>
      <div class="ls-right">
        <span class="ls-counter"><span id="ls-count">0</span>%</span>
      </div>
    </div>
    <div class="ls-progress-track">
      <div class="ls-progress-bar" id="ls-bar"></div>
    </div>

    <!-- Bordo curvo in basso -->
    <div class="rounded-div-wrap bottom">
      <div class="rounded-div"></div>
    </div>

  </div>
</div>

<style>
  /* ── Container ── */
  .loading-container {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: none;
    overflow: hidden;
  }

  .loading-screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: #0a0f1e;
    will-change: top;
    overflow: hidden;
  }

  /* ── Blobs ── */
  .ls-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0;
    animation: blobPulse 6s ease-in-out infinite;
    will-change: transform, opacity;
  }

  .ls-blob-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #455ce9 0%, transparent 70%);
    top: -10%;
    left: -8%;
    animation-delay: 0s;
    animation-duration: 7s;
  }

  .ls-blob-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #7c3aed 0%, transparent 70%);
    bottom: -5%;
    right: -5%;
    animation-delay: 1.5s;
    animation-duration: 9s;
  }

  .ls-blob-3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #0ea5e9 0%, transparent 70%);
    top: 40%;
    right: 15%;
    animation-delay: 0.8s;
    animation-duration: 8s;
  }

  @keyframes blobPulse {
    0%, 100% { transform: scale(1) translate(0, 0);   opacity: 0.18; }
    33%       { transform: scale(1.08) translate(20px, -15px); opacity: 0.25; }
    66%       { transform: scale(0.94) translate(-15px, 10px); opacity: 0.15; }
  }

  /* ── Griglia punti ── */
  .ls-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0;
    animation: gridFade 1.2s ease 0.3s forwards;
  }

  @keyframes gridFade {
    to { opacity: 1; }
  }

  /* ── Parole ── */
  .loading-words {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }

  .loading-words h2 {
    margin: 0;
    padding: 0 0.4em 0 0.6em;
    color: #fff;
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    display: none;
    white-space: nowrap;
    font-size: clamp(3.25em, 5vw, 4.5em);
    font-weight: 700;
    letter-spacing: -0.03em;
    will-change: opacity;
    text-shadow: 0 0 60px rgba(69, 92, 233, 0.5);
  }

  .loading-words h2.jap {
    font-size: calc(clamp(3.25em, 5vw, 4.5em) * 0.65);
    transform: translate(-50%, 10%);
  }

  .dot {
    display: block;
    position: absolute;
    border-radius: 50%;
    background: #455ce9;
    left: 0;
    top: 47%;
    width: calc(clamp(16px, 1.2vw, 19px) / 1.65);
    height: calc(clamp(16px, 1.2vw, 19px) / 1.65);
    box-shadow: 0 0 8px #455ce9;
  }

  @media screen and (max-width: 540px) {
    .dot { top: 42%; }
  }

  /* ── Footer ── */
  .ls-footer {
    position: absolute;
    bottom: 2.5rem;
    left: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    opacity: 0;
    animation: gridFade 0.8s ease 0.6s forwards;
  }

  .ls-name {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .ls-counter {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }

  #ls-count {
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
  }

  /* ── Progress bar ── */
  .ls-progress-track {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.06);
  }

  .ls-progress-bar {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #455ce9, #7c3aed);
    transform-origin: left center;
    transform: scaleX(0);
    box-shadow: 0 0 12px rgba(69, 92, 233, 0.8);
  }

  /* ── Curva in basso ── */
  .rounded-div-wrap {
    position: absolute;
    width: 110%;
    left: -5%;
    overflow: hidden;
    z-index: 2;
  }

  .rounded-div-wrap.bottom {
    bottom: 0;
    transform: translateY(99%);
    height: 0vh;
    will-change: height;
  }

  .rounded-div-wrap .rounded-div {
    width: 100%;
    height: 745%;
    background: #0a0f1e;
    border-radius: 50%;
  }
</style>

<script>
  (function () {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const alreadySeen = sessionStorage.getItem('zakka:intro-seen') === '1';

    // Skip intro se l'utente l'ha già vista o preferisce ridotto movimento
    if (alreadySeen || reduceMotion) {
      const c = document.querySelector<HTMLElement>('.loading-container');
      if (c) c.style.display = 'none';
      document.querySelectorAll<HTMLElement>('main .once-in').forEach((el) => {
        el.style.transform = 'none';
      });
      return;
    }

    const isMobile = window.innerWidth <= 540;
    const screen = document.querySelector<HTMLElement>('.loading-screen');
    const container = document.querySelector<HTMLElement>('.loading-container');
    const wordsEl = document.querySelector<HTMLElement>('.loading-words');
    const words = Array.from(document.querySelectorAll<HTMLElement>('.loading-words h2'));
    const bar = document.getElementById('ls-bar');
    const count = document.getElementById('ls-count');
    const curve = document.querySelector<HTMLElement>('.loading-screen .rounded-div-wrap.bottom');
    const onceIn = Array.from(document.querySelectorAll<HTMLElement>('main .once-in'));

    if (!screen || !container || !wordsEl || !bar || !curve) return;

    // Init
    document.documentElement.style.cursor = 'wait';
    document.body.style.overflow = 'hidden';
    onceIn.forEach((el) => (el.style.transform = `translateY(${isMobile ? '10vh' : '50vh'})`));
    curve.style.height = isMobile ? '5vh' : '10vh';
    words.forEach((w) => ((w.style.display = 'block'), (w.style.opacity = '0')));
    const first = words[0];
    const last = words[words.length - 1];
    if (first) first.style.opacity = '1';

    // Durata totale del caricamento visibile (ms)
    const LOAD_MS = 2200;
    const DELAY_MS = 500;

    // Contatore 0 → 100 + barra progresso
    const startCounter = performance.now() + DELAY_MS;
    function tickCounter(now: number) {
      const t = Math.min(1, Math.max(0, (now - startCounter) / LOAD_MS));
      const eased = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
      if (count) count.textContent = String(Math.round(eased * 100));
      if (bar) bar.style.transform = `scaleX(${eased})`;
      if (t < 1) requestAnimationFrame(tickCounter);
    }
    requestAnimationFrame(tickCounter);

    // Fade-in contenitore parole
    wordsEl.animate(
      [{ opacity: 0 }, { opacity: 1 }],
      { duration: 800, delay: DELAY_MS, fill: 'forwards', easing: 'cubic-bezier(0.22, 1, 0.36, 1)' }
    );

    // Ciclo parole: ogni parola resta visibile 150ms poi fade out quando parte la successiva
    const cycleStart = DELAY_MS + 400;
    const step = 150;
    words.forEach((w, i) => {
      if (i === 0) {
        w.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 1, delay: cycleStart + step, fill: 'forwards' });
        return;
      }
      const isLast = w === last;
      const keyframes = isLast
        ? [{ opacity: 0 }, { opacity: 1 }]
        : [{ opacity: 0 }, { opacity: 1, offset: 0.5 }, { opacity: 0 }];
      w.animate(keyframes, {
        duration: isLast ? 1 : step * 2,
        delay: cycleStart + step * i,
        fill: 'forwards',
      });
    });

    // Slide-out curtain
    const slideOutAt = cycleStart + step * words.length + 200;

    setTimeout(() => {
      screen.style.transition = 'top 850ms cubic-bezier(0.76, 0, 0.24, 1)';
      screen.style.top = '-100%';
      curve.style.transition = 'height 1000ms cubic-bezier(0.76, 0, 0.24, 1)';
      curve.style.height = '0vh';
      wordsEl.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 300, fill: 'forwards', easing: 'linear' });

      // Animazione contenuto principale (stagger)
      onceIn.forEach((el, i) => {
        el.style.transition = `transform 1500ms cubic-bezier(0.16, 1, 0.3, 1) ${i * 70}ms`;
        el.style.transform = 'translateY(0)';
      });

      setTimeout(() => {
        document.documentElement.style.cursor = 'auto';
      }, 650);

      setTimeout(() => {
        document.body.style.overflow = '';
        container.style.display = 'none';
        onceIn.forEach((el) => {
          el.style.transition = '';
          el.style.transform = '';
        });
        sessionStorage.setItem('zakka:intro-seen', '1');
      }, 1500);
    }, slideOutAt);
  })();
</script>
