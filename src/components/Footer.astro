---
import { getProfile, socialLinks } from '../data/profile';
import type { Locale } from '../data/types';
import SocialIcon from './SocialIcon.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'it' } = Astro.props;
const profile = getProfile(locale);

const labels = locale === 'en'
  ? {
      contacts: 'Contacts',
      rights: 'All rights reserved.',
      backToTop: 'Back to top',
      city: 'Rome',
      localeTag: 'en-GB',
    }
  : {
      contacts: 'Contatti',
      rights: 'Tutti i diritti riservati.',
      backToTop: "Torna all'inizio",
      city: 'Roma',
      localeTag: 'it-IT',
    };

const year = new Date().getFullYear();
---

<footer class="relative bg-paper dark:bg-surface-alt pt-[1px]">
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-500/50 to-transparent"></div>

  <div class="max-w-4xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center gap-8 sm:gap-0">

    <!-- Col 1: Brand -->
    <div class="flex flex-col gap-2 flex-1 items-center sm:items-start">
      <span class="font-serif italic text-2xl tracking-tight text-ink-900 dark:text-white" style="font-variation-settings: 'opsz' 96, 'SOFT' 100;">
        {profile.nickname}
      </span>
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.16em] text-ink-500 dark:text-white/45 leading-relaxed">
        {profile.title}
      </p>
      <p class="font-mono text-[0.7rem] text-ink-500 dark:text-white/45 flex items-center gap-1.5 mt-1 tabular-nums">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <span id="rome-time" data-locale={labels.localeTag} data-city={labels.city}></span>
      </p>
    </div>

    <!-- Separator -->
    <div class="hidden sm:block w-px self-stretch bg-gray-200 dark:bg-white/8 mx-8"></div>

    <!-- Col 2: Social -->
    <div class="flex flex-col gap-3 items-center">
      <span class="font-mono text-[0.65rem] font-medium uppercase tracking-[0.18em] text-ink-500 dark:text-white/45">
        / {labels.contacts}
      </span>
      <div class="flex items-center gap-3">
        {socialLinks.map(link => (
          <a
            href={link.href}
            target={link.icon !== 'mail' ? '_blank' : undefined}
            rel="noopener noreferrer"
            aria-label={link.label}
            data-tooltip={link.label}
            class="w-8 h-8 flex items-center justify-center rounded-full text-ink-500 dark:text-white/50 hover:text-accent-600 dark:hover:text-accent-400 border border-transparent hover:border-accent-500/40 transition-colors"
          >
            <SocialIcon icon={link.icon} class="w-4 h-4" />
          </a>
        ))}
      </div>
    </div>

    <!-- Separator -->
    <div class="hidden sm:block w-px self-stretch bg-gray-200 dark:bg-white/8 mx-8"></div>

    <!-- Col 3: Credits + back to top -->
    <div class="flex flex-1 items-center justify-end gap-6">
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.14em] text-ink-500 dark:text-white/45 text-right leading-relaxed">
        © {year} {profile.name}<br/>{labels.rights}
      </p>
      <button
        id="back-to-top"
        data-tooltip={labels.backToTop}
        aria-label={labels.backToTop}
        class="cursor-pointer group shrink-0 w-11 h-11 flex items-center justify-center rounded-full bg-ink-900 dark:bg-white text-paper dark:text-ink-900 active:scale-95 transition-all hover:-translate-y-0.5"
      >
        <svg class="w-3.5 h-3.5 transition-transform group-hover:-translate-y-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="18 15 12 9 6 15"/>
        </svg>
      </button>
    </div>

  </div>
</footer>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  function updateTime() {
    const el = document.getElementById('rome-time');
    if (!el) return;

    const localeTag = el.getAttribute('data-locale') || 'it-IT';
    const cityLabel = el.getAttribute('data-city') || 'Roma';

    const now = new Date();
    const time = now.toLocaleTimeString(localeTag, {
      timeZone: 'Europe/Rome',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
    });
    el.textContent = `${cityLabel} - ${time}`;
  }

  updateTime();
  setInterval(updateTime, 1000);
</script>
