---
import { experience } from '../data/experience';
---

<section id="experience" class="py-16 bg-white dark:bg-surface">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="section-title">Esperienza</h2>
    <ol class="relative border-l border-brand-100 dark:border-brand-700/40 space-y-10 ml-3">
      {experience.map(job => (
        <li class="pl-8 relative">
          <span class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-brand-500 border-2 border-white dark:border-surface ring-2 ring-brand-100 dark:ring-brand-700/40"></span>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <div class="flex items-center gap-4">
              {job.logo && (
                <div class="shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-xl border border-gray-100 dark:border-white/10 bg-white dark:bg-surface-card flex items-center justify-center overflow-hidden p-2 shadow-sm">
                  <img
                    src={job.logo}
                    alt={`Logo ${job.company}`}
                    class="w-full h-full object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{job.role}</h3>
                {job.url ? (
                  <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-brand-600 dark:text-brand-400 font-medium hover:underline underline-offset-2">{job.company} ↗</a>
                ) : (
                  <p class="text-brand-600 dark:text-brand-400 font-medium">{job.company}</p>
                )}
              </div>
            </div>
            <div class="text-right shrink-0">
              <p class="text-sm text-gray-500 dark:text-gray-400">{job.period}</p>
              <p class="text-sm text-gray-400 dark:text-gray-500">{job.location}</p>
            </div>
          </div>
          <ul class="mt-3 space-y-1 list-disc list-inside text-gray-600 dark:text-gray-300 text-sm">
            {job.description.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</section>
