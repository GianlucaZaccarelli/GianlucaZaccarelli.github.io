---
import { profile, socialLinks } from '../data/profile';
import SocialIcon from './SocialIcon.astro';
---

<header
  id="top"
  class="sticky top-0 z-50 transition-all duration-300"
  style="background: rgba(255,255,255,0.80); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <!-- Bottom gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-brand-500/60 to-transparent"></div>

  <nav class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">

    <!-- Logo / Name -->
    <a href="#top" class="group flex items-center gap-2 no-underline">
      <span class="font-extrabold text-base tracking-tight bg-gradient-to-r from-brand-600 to-violet-500 bg-clip-text text-transparent select-none">
        {profile.nickname}
      </span>
      <span class="hidden sm:inline text-xs text-gray-400 dark:text-gray-500 font-normal">
        / {profile.title}
      </span>
    </a>

    <!-- Nav links -->
    <ul class="hidden md:flex items-center text-sm font-medium text-gray-500 dark:text-gray-400">
      {[
        { href: '#about',      label: 'About'      },
        { href: '#experience', label: 'Esperienza' },
        { href: '#education',  label: 'Formazione' },
        { href: '#skills',     label: 'Skills'     },
        { href: '#projects',   label: 'Progetti'   },
        { href: '#contact',    label: 'Contatti'   },
      ].map(({ href, label }, i) => (
        <>
          {i > 0 && <span class="text-gray-200 dark:text-white/10 select-none px-0.5">|</span>}
          <li>
            <a
              href={href}
              class="relative px-3 py-1.5 rounded-md transition-colors hover:text-brand-600 dark:hover:text-brand-400 hover:bg-brand-50 dark:hover:bg-white/5"
            >
              {label}
            </a>
          </li>
        </>
      ))}
    </ul>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Social links (desktop) -->
      <div class="hidden sm:flex items-center gap-1 mr-1">
        {socialLinks.map(link => (
          <a
            href={link.href}
            target={link.icon !== 'mail' ? '_blank' : undefined}
            rel="noopener noreferrer"
            aria-label={link.label}
            data-tooltip={link.label}
            class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 dark:text-gray-500 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-brand-50 dark:hover:bg-white/10 transition-colors"
          >
            <SocialIcon icon={link.icon} class="w-4 h-4" />
          </a>
        ))}
      </div>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Cambia tema"
        data-tooltip="Tema scuro"
        class="cursor-pointer w-9 h-9 flex items-center justify-center rounded-lg text-gray-400 dark:text-gray-500 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-brand-50 dark:hover:bg-white/10 transition-colors"
      >
        <svg id="icon-sun" class="hidden dark:block w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" class="block dark:hidden w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Download CV (disabilitato temporaneamente) -->
      <span
        data-tooltip="CV non ancora disponibile"
        aria-disabled="true"
        class="inline-flex items-center gap-1.5 text-sm font-semibold bg-gray-300 dark:bg-white/10 text-gray-400 dark:text-white/25 px-4 py-2 rounded-lg cursor-not-allowed select-none opacity-60"
      >
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        CV
      </span>
    </div>
  </nav>
</header>

<!-- ── HERO ──────────────────────────────────────────── -->
<section id="hero" class="hero-section">

  <!-- Immagine centrale con parallax -->
  <div class="hero-img-wrap" id="hero-bg">
    <img
      src="/assets/MainImage.jpg"
      alt={profile.name}
      loading="eager"
      decoding="async"
      class="hero-img"
    />
  </div>

  <!-- Colonna sinistra -->
  <div class="hero-col hero-col-left">
    <div class="hero-location-badge">
      <h4 class="hero-subtitle">
        <span>Situato</span>
        in {profile.country}
      </h4>
      <p class="hero-availability">{profile.country}</p>
    </div>
    <div class="hero-scroll-hint">
      <div class="hero-scroll-line"></div>
      <span>Scroll</span>
    </div>
  </div>

  <!-- Colonna destra -->
  <div class="hero-col hero-col-right">
    <div class="hero-right-top">
      <span class="hero-mbti">{profile.mbti}</span>
    </div>
    <div class="hero-right-center">
      <h4 class="hero-subtitle">
        <span>{profile.titleLead}</span>
        {profile.titleRest}
      </h4>
      <p class="hero-availability">{profile.availability}</p>
    </div>
  </div>

  <!-- Marquee rolling name (bottom) -->
  <div class="hero-marquee-wrap" aria-hidden="true">
    <div class="hero-marquee-inner" id="hero-marquee-inner">
      <span class="hero-marquee-text">{profile.name}<em>—</em></span>
    </div>
  </div>

</section>

<style>
  /* ── Hero Section ── */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    background: #1C1D20;
    display: flex;
    align-items: center;
  }

  /* ── Immagine centrale ── */
  .hero-img-wrap {
    position: absolute;
    top: -10%;
    left: 0;
    width: 100%;
    height: 110%;
    will-change: transform;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }
  .hero-img {
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    pointer-events: none;
    user-select: none;
    /* Gradiente laterale per far emergere le colonne */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 18%,
      black 82%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 18%,
      black 82%,
      transparent 100%
    );
  }

  /* ── Colonne laterali ── */
  .hero-col {
    position: absolute;
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 2;
    padding: clamp(1.5rem, 3vw, 3rem);
  }
  .hero-col-left  { left: 0;  align-items: flex-start; }
  .hero-col-right { right: 0; align-items: flex-end; }

  /* Left: location badge */
  .hero-location-badge {
    display: flex;
    flex-direction: column;
  }

  /* Left: scroll hint */
  .hero-scroll-hint {
    position: absolute;
    bottom: clamp(1.5rem, 3vw, 3rem);
    left: clamp(1.5rem, 3vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.3);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* Right: top MBTI */
  .hero-right-top {
    position: absolute;
    top: clamp(1.5rem, 3vw, 3rem);
    right: clamp(1.5rem, 3vw, 3rem);
  }
  .hero-mbti {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  /* Right: subtitle centered */
  .hero-right-center {
    text-align: right;
  }
  .hero-subtitle {
    color: #fff;
    font-size: clamp(1.1rem, 1.8vw, 1.6rem);
    font-weight: 400;
    line-height: 1.3;
    margin: 0 0 0.4rem 0;
    letter-spacing: -0.01em;
  }
  .hero-subtitle span {
    display: block;
    font-weight: 700;
  }
  .hero-availability {
    color: rgba(255,255,255,0.4);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Marquee ── */
  .hero-marquee-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    z-index: 3;
    padding: 0.3rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: linear-gradient(to top, rgba(28,29,32,0.9), rgba(28,29,32,0.5));
  }
  .hero-marquee-inner {
    display: inline-flex;
    white-space: nowrap;
    will-change: transform;
  }
  .hero-marquee-text {
    font-size: max(3rem, 5vw);
    font-weight: 450;
    letter-spacing: -0.03em;
    color: #fff;
    padding-right: 0.4em;
    line-height: 1;
    display: inline-block;
    user-select: none;
  }
  .hero-marquee-text em {
    font-style: normal;
    color: #455CE9;
    padding: 0 0.15em;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .hero-col-left  { padding: 1.25rem; }
    .hero-col-right { padding: 1.25rem; }
    .hero-subtitle  { font-size: 1rem; }
    .hero-img {
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 10%,
        black 90%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 10%,
        black 90%,
        transparent 100%
      );
    }
  }
</style>

<script>
  import gsap from 'gsap';

  /* ── Navbar theme / shadow ── */
  const btn    = document.getElementById('theme-toggle');
  const header = document.getElementById('top') as HTMLElement | null;

  function applyHeaderTheme(isDark: boolean) {
    if (!header) return;
    header.style.background = isDark
      ? 'rgba(28,29,32,0.85)'
      : 'rgba(255,255,255,0.80)';
  }
  function updateTooltip(isDark: boolean) {
    btn?.setAttribute('data-tooltip', isDark ? 'Tema chiaro' : 'Tema scuro');
  }
  function syncTheme(isDark: boolean) {
    applyHeaderTheme(isDark);
    updateTooltip(isDark);
  }

  syncTheme(document.documentElement.classList.contains('dark'));

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncTheme(isDark);
  });

  /* ── Sync tema tra tab aperti ── */
  window.addEventListener('storage', (e) => {
    if (e.key !== 'theme') return;
    const isDark = e.newValue === 'dark';
    document.documentElement.classList.toggle('dark', isDark);
    syncTheme(isDark);
  });

  /* ── Scroll: header shadow + hero parallax (rAF throttled) ── */
  const heroBg = document.getElementById('hero-bg') as HTMLElement | null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const parallaxEnabled = !reduceMotion && window.innerWidth > 720;
  let scrollScheduled = false;
  function onScroll() {
    if (scrollScheduled) return;
    scrollScheduled = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      header?.classList.toggle('shadow-md', y > 8);
      if (parallaxEnabled && heroBg) heroBg.style.transform = `translateY(${y * 0.35}px)`;
      scrollScheduled = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  /* ── Marquee rolling (GSAP) ── */
  (function initMarquee() {
    const inner   = document.getElementById('hero-marquee-inner');
    const textEl  = inner?.querySelector('.hero-marquee-text') as HTMLElement | null;
    if (!inner || !textEl) return;

    // Clona il testo fino a riempire 3× la viewport
    const fill = () => {
      // Rimuovi cloni precedenti
      inner.querySelectorAll('.hero-marquee-clone').forEach(el => el.remove());
      const totalW  = textEl.offsetWidth;
      const needed  = Math.ceil((window.innerWidth * 3) / totalW) + 1;
      for (let i = 0; i < needed; i++) {
        const clone = textEl.cloneNode(true) as HTMLElement;
        clone.classList.add('hero-marquee-clone');
        inner.appendChild(clone);
      }
    };
    fill();
    window.addEventListener('resize', fill, { passive: true });

    let direction = 1; // 1 = forward, -1 = backward

    const tl: gsap.core.Timeline = gsap.timeline({
      repeat: -1,
      onReverseComplete() {
        tl.totalTime(tl.rawTime() + tl.duration() * 10);
      },
    });

    tl.to(inner, {
      xPercent: -100 / (inner.children.length),
      duration: 22,
      ease: 'none',
    });

    // Cambia direzione in base allo scroll
    let lastScrollY = window.scrollY;
    window.addEventListener('scroll', () => {
      const curr = window.scrollY;
      const newDir = curr > lastScrollY ? 1 : -1;
      if (newDir !== direction) {
        direction = newDir;
        gsap.to(tl, { timeScale: direction, duration: 0.5, overwrite: true });
      }
      lastScrollY = curr;
    }, { passive: true });
  })();
</script>
