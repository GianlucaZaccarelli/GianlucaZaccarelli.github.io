---
import { Image } from 'astro:assets';
import { getProfile } from '../data/profile';
import type { Locale } from '../data/types';
import mainImage from '../assets/MainImage.jpg';

interface Props {
  locale?: Locale;
}

const { locale = 'it' } = Astro.props;
const profile = getProfile(locale);

const itHref = import.meta.env.BASE_URL || '/';
const enHref = `${itHref.replace(/\/$/, '')}/en`;

const labels = locale === 'en'
  ? {
      about: 'About',
      experience: 'Experience',
      education: 'Education',
      projects: 'Projects',
      contacts: 'Contact',
      themeToggle: 'Toggle theme',
      darkTheme: 'Dark theme',
      downloadCv: 'Download CV (PDF)',
      openPrintableCv: 'Open printable CV',
      downloadCvAria: 'Download CV in PDF',
      openPrintableCvAria: 'Open printable CV',
      located: 'Located',
    }
  : {
      about: 'About',
      experience: 'Esperienza',
      education: 'Formazione',
      projects: 'Progetti',
      contacts: 'Contatti',
      themeToggle: 'Cambia tema',
      darkTheme: 'Tema scuro',
      downloadCv: 'Scarica CV (PDF)',
      openPrintableCv: 'Apri CV stampabile',
      downloadCvAria: 'Scarica CV in PDF',
      openPrintableCvAria: 'Apri CV stampabile',
      located: 'Situato',
    };

const cvHref = import.meta.env.DEV ? '/cv-print' : profile.cvPath;
const isCvDownload = !import.meta.env.DEV;
---

<header
  id="top"
  class="sticky top-0 z-50 transition-all duration-300"
  style="background: rgba(255,255,255,0.80); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <!-- Bottom accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-500/50 to-transparent"></div>

  <nav class="max-w-6xl mx-auto px-6 py-3 grid grid-cols-[auto_1fr_auto] items-center gap-6">

    <!-- Logo / Name -->
    <a href="#top" class="group brand-mark flex items-center gap-2.5 no-underline whitespace-nowrap">
      <span class="brand-word font-serif text-xl tracking-tight text-ink-900 dark:text-white italic select-none leading-none" style="font-variation-settings: 'opsz' 96, 'SOFT' 100;">
        {profile.nickname}
      </span>
      <span class="hidden lg:inline-flex h-4 w-px bg-ink-300/60 dark:bg-white/15"></span>
      <span class="hidden lg:inline font-mono text-[0.6rem] uppercase tracking-[0.16em] text-ink-500 dark:text-white/45 font-medium leading-none">
        Full-Stack Dev
      </span>
    </a>

    <!-- Tab bar -->
    <div class="hidden md:flex justify-center">
      <ul
        role="tablist"
        class="tab-bar inline-flex items-center gap-1 p-1 rounded-full border border-ink-300/60 dark:border-white/10 bg-white/60 dark:bg-white/5 backdrop-blur-sm"
      >
        {[
          { href: '#about',      label: labels.about      },
          { href: '#experience', label: labels.experience },
          { href: '#education',  label: labels.education  },
          { href: '#skills',     label: 'Skills'          },
          { href: '#projects',   label: labels.projects   },
          { href: '#contact',    label: labels.contacts   },
        ].map(({ href, label }) => (
          <li>
            <a
              href={href}
              data-target={href}
              class="tab-link relative inline-flex items-center px-3.5 py-1.5 rounded-full font-mono text-[0.7rem] uppercase tracking-[0.12em] font-medium text-ink-500 dark:text-white/55 hover:text-ink-900 dark:hover:text-white transition-colors"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 justify-self-end">
      <!-- Language toggle -->
      <div
        role="group"
        aria-label="Language"
        class="lang-toggle inline-flex items-center p-0.5 rounded-full border border-ink-300/60 dark:border-white/15 bg-white/60 dark:bg-white/5"
      >
        <a
          href={itHref}
          aria-label="Italiano"
          title="Italiano"
          class:list={['lang-option', { 'is-active': locale === 'it' }]}
          aria-current={locale === 'it' ? 'page' : undefined}
        >
          <svg class="flag" viewBox="0 0 3 2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="1" height="2" x="0" fill="#009246"/>
            <rect width="1" height="2" x="1" fill="#ffffff"/>
            <rect width="1" height="2" x="2" fill="#ce2b37"/>
          </svg>
        </a>
        <a
          href={enHref}
          aria-label="English"
          title="English"
          class:list={['lang-option', { 'is-active': locale === 'en' }]}
          aria-current={locale === 'en' ? 'page' : undefined}
        >
          <svg class="flag" viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <clipPath id="uk-clip"><rect width="60" height="30"/></clipPath>
            <g clip-path="url(#uk-clip)">
              <rect width="60" height="30" fill="#012169"/>
              <path d="M0,0 L60,30 M60,0 L0,30" stroke="#ffffff" stroke-width="6"/>
              <path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4" clip-path="polygon(0 0, 50% 50%, 100% 0, 100% 100%, 50% 50%, 0 100%)"/>
              <path d="M30,0 V30 M0,15 H60" stroke="#ffffff" stroke-width="10"/>
              <path d="M30,0 V30 M0,15 H60" stroke="#c8102e" stroke-width="6"/>
            </g>
          </svg>
        </a>
      </div>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label={labels.themeToggle}
        data-tooltip={labels.darkTheme}
        class="theme-toggle cursor-pointer relative w-9 h-9 flex items-center justify-center rounded-full"
      >
        <svg class="theme-toggle-icon icon-sun w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <g class="sun-rays">
            <line x1="12" y1="2" x2="12" y2="4"/>
            <line x1="12" y1="20" x2="12" y2="22"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="2" y1="12" x2="4" y2="12"/>
            <line x1="20" y1="12" x2="22" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </g>
        </svg>
        <svg class="theme-toggle-icon icon-moon w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Download CV -->
      <a
        href={cvHref}
        download={isCvDownload}
        data-tooltip={isCvDownload ? labels.downloadCv : labels.openPrintableCv}
        aria-label={isCvDownload ? labels.downloadCvAria : labels.openPrintableCvAria}
        class="cv-button group inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.14em] font-medium bg-ink-900 dark:bg-white text-paper dark:text-ink-900 px-4 py-2.5 rounded-full transition-all"
      >
        <svg class="w-3 h-3 transition-transform group-hover:translate-y-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        CV
      </a>
    </div>
  </nav>
</header>

<!-- ── HERO ──────────────────────────────────────────── -->
<section id="hero" class="hero-section">

  <!-- Immagine centrale con parallax -->
  <div class="hero-img-wrap" id="hero-bg">
    <Image
      src={mainImage}
      alt={profile.name}
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="hero-img"
    />
    <!-- Noise texture overlay -->
    <div class="grain-overlay"></div>
    <!-- Vignette -->
    <div class="hero-vignette" aria-hidden="true"></div>
  </div>

  <!-- Colonna sinistra -->
  <div class="hero-col hero-col-left">
    <div class="hero-location-badge">
      <span class="hero-index">N° 00 / Portfolio</span>
      <h4 class="hero-subtitle">
        <span>{labels.located}</span>
        in {profile.country}
      </h4>
      <p class="hero-availability">— {profile.city}</p>
    </div>
    <div class="hero-scroll-hint">
      <div class="hero-scroll-line"></div>
      <span>Scroll</span>
    </div>
  </div>

  <!-- Colonna destra -->
  <div class="hero-col hero-col-right">
    <div class="hero-right-top">
      <span class="hero-mbti">{profile.mbti} · MMXXVI</span>
    </div>
    <div class="hero-right-center">
      <h4 class="hero-subtitle">
        <span>{profile.titleLead}</span>
        <em>{profile.titleRest}</em>
      </h4>
      <p class="hero-availability">{profile.availability}</p>
    </div>
  </div>

  <!-- Marquee rolling name (bottom) -->
  <div class="hero-marquee-wrap" aria-hidden="true">
    <div class="hero-marquee-inner" id="hero-marquee-inner">
      <span class="hero-marquee-text">{profile.name}<em>—</em></span>
    </div>
  </div>

</section>

<style>
  /* ── Hero Section ── */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    background: #0f1012;
    display: flex;
    align-items: center;
  }

  /* ── Immagine centrale ── */
  .hero-img-wrap {
    position: absolute;
    top: -10%;
    left: 0;
    width: 100%;
    height: 110%;
    will-change: transform;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }
  .hero-img {
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    pointer-events: none;
    user-select: none;
    filter: grayscale(20%) contrast(1.05);
    /* Gradiente laterale per far emergere le colonne */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 18%,
      black 82%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 18%,
      black 82%,
      transparent 100%
    );
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at center, transparent 40%, rgba(15,16,18,0.55) 100%),
      linear-gradient(to bottom, transparent 60%, rgba(15,16,18,0.9) 100%);
  }

  /* ── Colonne laterali ── */
  .hero-col {
    position: absolute;
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 2;
    padding: clamp(1.5rem, 3vw, 3rem);
  }
  .hero-col-left  { left: 0;  align-items: flex-start; }
  .hero-col-right { right: 0; align-items: flex-end; }

  /* Left: location badge */
  .hero-location-badge {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hero-index {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.14);
    align-self: flex-start;
    margin-bottom: 0.2rem;
  }

  /* Left: scroll hint */
  .hero-scroll-hint {
    position: absolute;
    bottom: clamp(1.5rem, 3vw, 3rem);
    left: clamp(1.5rem, 3vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.35);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .hero-scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* Right: top MBTI */
  .hero-right-top {
    position: absolute;
    top: clamp(1.5rem, 3vw, 3rem);
    right: clamp(1.5rem, 3vw, 3rem);
  }
  .hero-mbti {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    padding: 0.35rem 0.75rem;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

  /* Right: subtitle centered */
  .hero-right-center {
    text-align: right;
  }
  .hero-subtitle {
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.1vw, 1.9rem);
    font-weight: 400;
    line-height: 1.15;
    margin: 0 0 0.6rem 0;
    letter-spacing: -0.02em;
    font-variation-settings: 'opsz' 96, 'SOFT' 100;
  }
  .hero-subtitle span {
    display: block;
    font-style: normal;
    font-weight: 500;
  }
  .hero-subtitle em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent-400, #e8a28c);
  }
  .hero-availability {
    color: rgba(255,255,255,0.45);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Marquee ── */
  .hero-marquee-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    z-index: 3;
    padding: 0.3rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: linear-gradient(to top, rgba(28,29,32,0.9), rgba(28,29,32,0.5));
  }
  .hero-marquee-inner {
    display: inline-flex;
    white-space: nowrap;
    will-change: transform;
  }
  .hero-marquee-text {
    font-family: var(--font-serif);
    font-size: max(3.25rem, 5.5vw);
    font-weight: 400;
    letter-spacing: -0.045em;
    color: #fff;
    padding-right: 0.4em;
    line-height: 1;
    display: inline-block;
    user-select: none;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .hero-marquee-text em {
    font-style: italic;
    color: var(--color-accent-400, #e8a28c);
    padding: 0 0.15em;
  }

  /* ── Brand mark ── */
  .brand-mark {
    padding: 0.42rem 0.85rem 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(28, 29, 32, 0.10);
    background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,246,241,0.85));
    box-shadow:
      0 1px 0 rgba(255,255,255,0.75) inset,
      0 8px 24px rgba(15,16,18,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  :global(.dark) .brand-mark {
    border-color: rgba(255,255,255,0.12);
    background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    box-shadow:
      0 1px 0 rgba(255,255,255,0.06) inset,
      0 10px 24px rgba(0,0,0,0.18);
  }
  .brand-mark:hover {
    transform: translateY(-1px);
    border-color: rgba(192, 97, 26, 0.28);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.8) inset,
      0 10px 28px rgba(15,16,18,0.12);
  }
  :global(.dark) .brand-mark:hover {
    border-color: rgba(232, 162, 140, 0.28);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.08) inset,
      0 12px 28px rgba(0,0,0,0.24);
  }
  .brand-word {
    font-size: 1.12rem;
    letter-spacing: -0.07em;
    text-shadow: 0 1px 0 rgba(255,255,255,0.7);
  }
  :global(.dark) .brand-word {
    text-shadow: 0 1px 0 rgba(0,0,0,0.35);
  }

  /* ── Language toggle (segmented pill) ── */
  .lang-toggle {
    backdrop-filter: blur(6px);
    transition: border-color 0.3s ease;
  }
  .lang-option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem 0.5rem;
    border-radius: 999px;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-decoration: none;
    opacity: 0.55;
  }
  .lang-option:hover {
    opacity: 1;
    transform: translateY(-1px);
  }
  .lang-option.is-active {
    opacity: 1;
    background: rgba(0, 0, 0, 0.06);
  }
  :global(.dark) .lang-option.is-active {
    background: rgba(255, 255, 255, 0.12);
  }
  .flag {
    width: 1.15rem;
    height: 0.8rem;
    border-radius: 2px;
    display: block;
    box-shadow: 0 0 0 0.5px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  /* ── Theme toggle (subtle animated) ── */
  .theme-toggle {
    color: #c0611a;
    background: rgba(192, 97, 26, 0.08);
    border: 1px solid rgba(192, 97, 26, 0.22);
    transition: color 0.35s ease, background-color 0.3s ease,
                border-color 0.3s ease, transform 0.2s ease,
                box-shadow 0.3s ease;
  }
  :global(.dark) .theme-toggle {
    color: #a5b4fc;
    background: rgba(165, 180, 252, 0.08);
    border-color: rgba(165, 180, 252, 0.22);
  }
  .theme-toggle:hover {
    background: rgba(192, 97, 26, 0.16);
    border-color: rgba(192, 97, 26, 0.4);
    color: #9a4a10;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px rgba(192, 97, 26, 0.35);
  }
  :global(.dark) .theme-toggle:hover {
    background: rgba(165, 180, 252, 0.16);
    border-color: rgba(165, 180, 252, 0.4);
    color: #c7d2fe;
    box-shadow: 0 4px 12px -4px rgba(165, 180, 252, 0.35);
  }
  .theme-toggle:active {
    transform: scale(0.95);
  }

  .theme-toggle-icon {
    position: absolute;
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
                opacity 0.3s ease;
  }
  .icon-sun {
    transform: rotate(0deg) scale(1);
    opacity: 1;
  }
  .icon-moon {
    transform: rotate(-90deg) scale(0.5);
    opacity: 0;
  }
  :global(.dark) .icon-sun {
    transform: rotate(90deg) scale(0.5);
    opacity: 0;
  }
  :global(.dark) .icon-moon {
    transform: rotate(0deg) scale(1);
    opacity: 1;
  }

  .sun-rays {
    transform-origin: 12px 12px;
    transition: transform 0.6s ease;
  }
  .theme-toggle:hover .icon-sun .sun-rays {
    transform: rotate(45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle-icon,
    .sun-rays { transition: none; }
  }

  /* ── Tab bar ── */
  .tab-link {
    position: relative;
    z-index: 1;
  }
  .tab-link.is-active {
    background: var(--color-ink-900, #1c1d20);
    color: var(--color-paper, #fafaf7);
  }
  :global(.dark) .tab-link.is-active {
    background: rgba(255, 255, 255, 0.92);
    color: #1c1d20;
  }

  /* ── CV button hover ── */
  .cv-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px -4px rgba(0,0,0,0.15);
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .hero-col-left  { padding: 1.25rem; }
    .hero-col-right { padding: 1.25rem; }
    .hero-subtitle  { font-size: 1rem; }
    .hero-img {
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 10%,
        black 90%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 10%,
        black 90%,
        transparent 100%
      );
    }
  }
</style>

<script>
  /* ── Navbar theme / shadow ── */
  const btn    = document.getElementById('theme-toggle');
  const header = document.getElementById('top') as HTMLElement | null;

  function applyHeaderTheme(isDark: boolean) {
    if (!header) return;
    header.style.background = isDark
      ? 'rgba(28,29,32,0.85)'
      : 'rgba(255,255,255,0.80)';
  }
  function updateTooltip(isDark: boolean) {
    btn?.setAttribute('data-tooltip', isDark ? 'Tema chiaro' : 'Tema scuro');
  }
  function syncTheme(isDark: boolean) {
    applyHeaderTheme(isDark);
    updateTooltip(isDark);
  }

  syncTheme(document.documentElement.classList.contains('dark'));

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncTheme(isDark);
  });

  /* ── Sync tema tra tab aperti ── */
  window.addEventListener('storage', (e) => {
    if (e.key !== 'theme') return;
    const isDark = e.newValue === 'dark';
    document.documentElement.classList.toggle('dark', isDark);
    syncTheme(isDark);
  });

  /* ── Scroll: header shadow + hero parallax (rAF throttled) ── */
  const heroBg = document.getElementById('hero-bg') as HTMLElement | null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const parallaxEnabled = !reduceMotion && window.innerWidth > 720;
  let scrollScheduled = false;
  function onScroll() {
    if (scrollScheduled) return;
    scrollScheduled = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      header?.classList.toggle('shadow-md', y > 8);
      if (parallaxEnabled && heroBg) heroBg.style.transform = `translateY(${y * 0.35}px)`;
      scrollScheduled = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  /* ── Tab bar scrollspy ── */
  (function initTabSpy() {
    const tabs = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('.tab-link[data-target]')
    );
    if (tabs.length === 0) return;

    const sections = tabs
      .map((tab) => {
        const id = tab.dataset.target?.replace('#', '');
        const el = id ? document.getElementById(id) : null;
        return el ? { tab, el } : null;
      })
      .filter((x): x is { tab: HTMLAnchorElement; el: HTMLElement } => x !== null);

    const setActive = (tab: HTMLAnchorElement) => {
      tabs.forEach((t) => t.classList.toggle('is-active', t === tab));
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visible) return;
        const match = sections.find((s) => s.el === visible.target);
        if (match) setActive(match.tab);
      },
      { rootMargin: '-35% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] }
    );

    sections.forEach(({ el }) => observer.observe(el));
  })();

  /* ── Marquee rolling (WAAPI) ── */
  (function initMarquee() {
    const inner   = document.getElementById('hero-marquee-inner');
    const textEl  = inner?.querySelector('.hero-marquee-text') as HTMLElement | null;
    if (!inner || !textEl) return;

    let animation: Animation | null = null;

    const build = () => {
      inner.querySelectorAll('.hero-marquee-clone').forEach((el) => el.remove());
      const totalW = textEl.offsetWidth;
      if (totalW === 0) return;
      const needed = Math.ceil((window.innerWidth * 3) / totalW) + 1;
      for (let i = 0; i < needed; i++) {
        const clone = textEl.cloneNode(true) as HTMLElement;
        clone.classList.add('hero-marquee-clone');
        inner.appendChild(clone);
      }

      const totalChildren = inner.children.length;
      const distancePct = 100 / totalChildren;
      animation?.cancel();
      animation = inner.animate(
        [{ transform: 'translateX(0)' }, { transform: `translateX(-${distancePct}%)` }],
        { duration: 22000, iterations: Infinity, easing: 'linear' }
      );
    };

    build();
    window.addEventListener('resize', build, { passive: true });

    let direction = 1;
    let lastScrollY = window.scrollY;
    window.addEventListener(
      'scroll',
      () => {
        const curr = window.scrollY;
        const newDir = curr > lastScrollY ? 1 : -1;
        if (newDir !== direction && animation) {
          direction = newDir;
          animation.playbackRate = direction;
        }
        lastScrollY = curr;
      },
      { passive: true }
    );
  })();
</script>
