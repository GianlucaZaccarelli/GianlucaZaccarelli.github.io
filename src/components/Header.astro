---
import { profile, socialLinks } from '../data/profile';
import SocialIcon from './SocialIcon.astro';
---

<header
  id="top"
  class="sticky top-0 z-50 transition-all duration-300"
  style="background: rgba(255,255,255,0.80); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <!-- Bottom gradient accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/40 to-transparent"></div>

  <nav class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">

    <!-- Logo / Name -->
    <a href="#top" class="group flex items-center gap-2 no-underline">
      <span class="font-extrabold text-base tracking-tight bg-gradient-to-r from-brand-600 to-violet-500 bg-clip-text text-transparent select-none">
        {profile.nickname}
      </span>
      <span class="hidden sm:inline text-xs text-gray-400 dark:text-gray-500 font-normal">
        / {profile.title}
      </span>
    </a>

    <!-- Nav links -->
    <ul class="hidden md:flex items-center gap-1 text-sm font-medium text-gray-500 dark:text-gray-400">
      {[
        { href: '#about',      label: 'About'      },
        { href: '#experience', label: 'Esperienza' },
        { href: '#education',  label: 'Formazione' },
        { href: '#skills',     label: 'Skills'     },
        { href: '#projects',   label: 'Progetti'   },
        { href: '#contact',    label: 'Contatti'   },
      ].map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="relative px-3 py-1.5 rounded-md transition-colors hover:text-brand-600 dark:hover:text-brand-400 hover:bg-brand-50 dark:hover:bg-white/5"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Cambia tema"
        data-tooltip="Tema scuro"
        class="cursor-pointer w-9 h-9 flex items-center justify-center rounded-lg text-gray-400 dark:text-gray-500 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-brand-50 dark:hover:bg-white/10 transition-colors"
      >
        <svg id="icon-sun" class="hidden dark:block w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" class="block dark:hidden w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Download CV -->
      <a
        href={profile.cvPath}
        download
        data-tooltip="Scarica il curriculum"
        class="inline-flex items-center gap-1.5 text-sm font-semibold bg-brand-600 hover:bg-brand-700 active:scale-95 text-white px-4 py-2 rounded-lg shadow-sm shadow-brand-600/30 transition-all"
      >
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        CV
      </a>
    </div>
  </nav>
</header>

<section id="hero" class="bg-white dark:bg-surface">
  <div class="max-w-4xl mx-auto px-6 py-20 flex flex-col sm:flex-row items-center gap-10">
    <div class="shrink-0">
      <img
        src="/assets/profile.jpg"
        alt={profile.name}
        width="128"
        height="128"
        loading="eager"
        decoding="async"
        class="w-32 h-32 rounded-full object-cover ring-2 ring-brand-200 dark:ring-brand-700/50"
      />
    </div>
    <div class="text-center sm:text-left">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white">{profile.name}</h1>
      <p class="mt-2 text-xl text-brand-600 dark:text-brand-400 font-medium">{profile.title}</p>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{profile.location} &middot; {profile.availability}</p>
      <div class="mt-5 flex flex-wrap justify-center sm:justify-start gap-3">
        {socialLinks.map(link => (
          <a
            href={link.href}
            target={link.icon !== 'mail' ? '_blank' : undefined}
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-white/15 rounded-lg px-4 py-2 hover:border-brand-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
          >
            <SocialIcon icon={link.icon} class="w-4 h-4" />
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('theme-toggle');
  const header = document.getElementById('top') as HTMLElement | null;

  function applyHeaderTheme(isDark: boolean) {
    if (!header) return;
    header.style.background = isDark
      ? 'rgba(28,29,32,0.85)'
      : 'rgba(255,255,255,0.80)';
  }

  function updateTooltip(isDark: boolean) {
    btn?.setAttribute('data-tooltip', isDark ? 'Tema chiaro' : 'Tema scuro');
  }

  // Scroll shadow
  window.addEventListener('scroll', () => {
    if (!header) return;
    if (window.scrollY > 8) {
      header.classList.add('shadow-md');
    } else {
      header.classList.remove('shadow-md');
    }
  }, { passive: true });

  const isDark = document.documentElement.classList.contains('dark');
  applyHeaderTheme(isDark);
  updateTooltip(isDark);

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    applyHeaderTheme(isDark);
    updateTooltip(isDark);
  });
</script>
