---
import { profile, socialLinks } from '../data/profile';
import SocialIcon from './SocialIcon.astro';
---

<header id="top" class="bg-white dark:bg-surface border-b border-gray-100 dark:border-white/10 sticky top-0 z-50">
  <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
    <span class="font-bold text-gray-900 dark:text-white">{profile.name}</span>
    <ul class="hidden sm:flex items-center gap-6 text-sm text-gray-600 dark:text-gray-400">
      <li><a href="#about" class="hover:text-brand-600 transition-colors">About</a></li>
      <li><a href="#experience" class="hover:text-brand-600 transition-colors">Esperienza</a></li>
      <li><a href="#education" class="hover:text-brand-600 transition-colors">Formazione</a></li>
      <li><a href="#skills" class="hover:text-brand-600 transition-colors">Skills</a></li>
      <li><a href="#projects" class="hover:text-brand-600 transition-colors">Progetti</a></li>
      <li><a href="#contact" class="hover:text-brand-600 transition-colors">Contatti</a></li>
    </ul>
    <div class="flex items-center gap-3">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Cambia tema"
        data-tooltip="Tema scuro"
        class="cursor-pointer w-9 h-9 flex items-center justify-center rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" class="hidden dark:block w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" class="block dark:hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a
        href={profile.cvPath}
        download
        data-tooltip="Scarica il curriculum"
        class="text-sm font-medium bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors"
      >
        Scarica CV
      </a>
    </div>
  </nav>
</header>

<section id="hero" class="bg-white dark:bg-surface">
  <div class="max-w-4xl mx-auto px-6 py-20 flex flex-col sm:flex-row items-center gap-10">
    <div class="shrink-0">
      <img
        src="/assets/profile.jpg"
        alt={profile.name}
        width="128"
        height="128"
        loading="eager"
        decoding="async"
        class="w-32 h-32 rounded-full object-cover ring-2 ring-brand-200 dark:ring-brand-700/50"
      />
    </div>
    <div class="text-center sm:text-left">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white">{profile.name}</h1>
      <p class="mt-2 text-xl text-brand-600 dark:text-brand-400 font-medium">{profile.title}</p>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{profile.location} &middot; {profile.availability}</p>
      <div class="mt-5 flex flex-wrap justify-center sm:justify-start gap-3">
        {socialLinks.map(link => (
          <a
            href={link.href}
            target={link.icon !== 'mail' ? '_blank' : undefined}
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-white/15 rounded-lg px-4 py-2 hover:border-brand-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
          >
            <SocialIcon icon={link.icon} class="w-4 h-4" />
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('theme-toggle');

  function updateTooltip(isDark: boolean) {
    btn?.setAttribute('data-tooltip', isDark ? 'Tema chiaro' : 'Tema scuro');
  }

  // Set correct tooltip on load
  updateTooltip(document.documentElement.classList.contains('dark'));

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateTooltip(isDark);
  });
</script>
