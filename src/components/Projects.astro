---
import { projects } from '../data/projects';

const BASE = 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons';

const iconMap: Record<string, string> = {
  'Astro':           `${BASE}/astro/astro-original.svg`,
  'TypeScript':      `${BASE}/typescript/typescript-original.svg`,
  'JavaScript':      `${BASE}/javascript/javascript-original.svg`,
  'Tailwind CSS':    `${BASE}/tailwindcss/tailwindcss-original.svg`,
  'GitHub Actions':  `${BASE}/github/github-original.svg`,
  'C#':              `${BASE}/csharp/csharp-original.svg`,
  '.NET':            `${BASE}/dotnetcore/dotnetcore-original.svg`,
  'Docker':          `${BASE}/docker/docker-original.svg`,
  'Kubernetes':      `${BASE}/kubernetes/kubernetes-plain.svg`,
  'SQL':             `${BASE}/microsoftsqlserver/microsoftsqlserver-plain.svg`,
  'Node.js':         `${BASE}/nodejs/nodejs-original.svg`,
  'Git':             `${BASE}/git/git-original.svg`,
  'HTML5':           `${BASE}/html5/html5-original.svg`,
  'CSS3':            `${BASE}/css3/css3-original.svg`,
};
---

<section id="projects" class="py-16 bg-gray-50 dark:bg-surface-alt">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="section-title">Progetti</h2>
    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map(project => (
        <article class="bg-white dark:bg-surface-card rounded-xl border border-gray-100 dark:border-white/10 p-6 flex flex-col gap-4 hover:shadow-md dark:hover:shadow-black/30 transition-shadow">
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-white text-lg">{project.title}</h3>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-2 leading-relaxed">{project.description}</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {project.stack.map(tech => {
              const icon = iconMap[tech];
              return (
                <span class:list={['tech-badge', { 'has-icon': !!icon }]}>
                  {icon && (
                    <img src={icon} alt={tech} width="14" height="14" loading="lazy" decoding="async" class="tech-icon" />
                  )}
                  {tech}
                </span>
              );
            })}
          </div>
          <div class="flex gap-3 mt-auto pt-2 items-center">
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-medium text-brand-600 dark:text-brand-400 hover:underline"
              >
                GitHub →
              </a>
            )}
            {project.demo && (
              <a
                href={project.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:underline"
              >
                Demo →
              </a>
            )}
            {!project.github && !project.demo && (
              <span class="text-xs text-gray-400 dark:text-gray-600 italic">Progetto interno — non pubblico</span>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    font-size: 0.72rem;
    font-family: ui-monospace, monospace;
    border-radius: 0.375rem;
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #e2e8f0;
  }

  :global(.dark) .tech-badge {
    background: rgba(255,255,255,0.07);
    color: #cbd5e1;
    border-color: rgba(255,255,255,0.1);
  }

  .tech-badge.has-icon {
    border-color: rgba(69, 92, 233, 0.2);
    background: rgba(69, 92, 233, 0.05);
    color: #3b4fd4;
  }

  :global(.dark) .tech-badge.has-icon {
    background: rgba(69, 92, 233, 0.12);
    border-color: rgba(69, 92, 233, 0.3);
    color: #a5b4fc;
  }

  .tech-icon {
    width: 14px;
    height: 14px;
    object-fit: contain;
    flex-shrink: 0;
  }
</style>
