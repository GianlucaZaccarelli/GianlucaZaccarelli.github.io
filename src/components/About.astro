---
import { profile } from '../data/profile';

const flagMap: Record<string, string> = {
  'Italiano': '🇮🇹',
  'Inglese':  '🇬🇧',
};
---

<section id="about" class="py-16 bg-gray-50 dark:bg-surface-alt">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="section-title">Chi sono</h2>
    <div class="grid sm:grid-cols-3 gap-10">

      <div class="sm:col-span-2 relative">
        <div class="space-y-2">
          <span class="block text-6xl leading-none text-brand-200 dark:text-brand-700/50 font-serif select-none -mb-4" aria-hidden="true">"</span>

          <!-- Frase 1: personalità e leadership -->
          <p class="text-gray-800 dark:text-gray-100 text-lg leading-relaxed font-medium">
            Sono una persona <mark class="bg-transparent text-brand-600 dark:text-brand-400 font-semibold">determinata e ambiziosa</mark>,
            con spiccate doti di <mark class="bg-transparent text-brand-600 dark:text-brand-400 font-semibold">leadership</mark> e
            una forte inclinazione alla <mark class="bg-transparent text-brand-600 dark:text-brand-400 font-semibold">pianificazione strategica</mark>.
          </p>

          <!-- Frase 2: obiettivi e approccio -->
          <p class="text-gray-600 dark:text-gray-300 text-base leading-relaxed">
            Mi concentro sul raggiungimento degli obiettivi, affrontando le sfide con
            <mark class="bg-transparent text-gray-800 dark:text-gray-100 font-medium">sicurezza, razionalità e un approccio analitico</mark>.
            Comunico in modo chiaro e diretto, motivando e guidando chi mi circonda verso il successo.
          </p>

          <!-- Frase 3: psicologia — elemento differenziante -->
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed border-l-2 border-brand-200 dark:border-brand-700/50 pl-4 italic">
            Sto approfondendo questi aspetti con una
            <mark class="bg-transparent text-brand-600 dark:text-brand-400 not-italic font-medium">Laurea in Scienze Psicologiche</mark>,
            per unire alla solidità tecnica una comprensione più profonda delle persone e dei team.
          </p>

          <span class="block text-6xl leading-none text-brand-200 dark:text-brand-700/50 font-serif select-none text-right -mt-4" aria-hidden="true">"</span>
        </div>
      </div>

      <!-- Sidebar info -->
      <div class="space-y-5 text-sm">
        <div>
          <p class="text-xs font-semibold text-brand-600 dark:text-brand-400 uppercase tracking-wider mb-1">Posizione</p>
          <p class="text-gray-700 dark:text-gray-300">{profile.location}</p>
        </div>
        <div>
          <p class="text-xs font-semibold text-brand-600 dark:text-brand-400 uppercase tracking-wider mb-1">Lingue</p>
          <ul class="space-y-1">
            {profile.languages.map(lang => {
              const key = lang.split(' ')[0];
              const flag = flagMap[key] ?? '';
              return (
                <li class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                  <span class="text-base leading-none">{flag}</span>
                  <span>{lang}</span>
                </li>
              );
            })}
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold text-brand-600 dark:text-brand-400 uppercase tracking-wider mb-1">Personalità</p>
          <p class="text-gray-700 dark:text-gray-300">MBTI — <span class="font-semibold">{profile.mbti}</span></p>
        </div>
        <div>
          <p class="text-xs font-semibold text-brand-600 dark:text-brand-400 uppercase tracking-wider mb-1">Disponibilità</p>
          <p class="text-gray-700 dark:text-gray-300">{profile.availability}</p>
        </div>
      </div>

    </div>
  </div>
</section>
