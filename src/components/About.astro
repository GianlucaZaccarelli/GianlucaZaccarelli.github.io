---
import { getProfile } from '../data/profile';
import type { Locale } from '../data/types';

interface Props {
  locale?: Locale;
}

const { locale = 'it' } = Astro.props;
const profile = getProfile(locale);

const labels = locale === 'en'
  ? {
      sectionTitle: 'Who I am',
      sectionTitleEm: 'am',
      eyebrow: 'About',
      position: 'Location',
      languages: 'Languages',
      personality: 'Personality',
      availability: 'Availability',
    }
  : {
      sectionTitle: 'Chi sono',
      sectionTitleEm: 'sono',
      eyebrow: 'Chi sono',
      position: 'Posizione',
      languages: 'Lingue',
      personality: 'Personalità',
      availability: 'Disponibilità',
    };

const flagMap: Record<string, string> = {
  Italiano: '🇮🇹',
  Inglese: '🇬🇧',
  Italian: '🇮🇹',
  English: '🇬🇧',
};

const [bioLead, bioBody, bioTail] = profile.bioParagraphs;
const titleBase = labels.sectionTitle.replace(labels.sectionTitleEm, '').trim();
---

<section id="about" class="relative py-24 md:py-32 bg-paper dark:bg-surface-alt overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Editorial header -->
    <div class="section-eyebrow">
      <span class="eyebrow-num">·01</span>
      <span class="eyebrow-line"></span>
      <span>{labels.eyebrow}</span>
    </div>

    <h2 class="section-title">
      {titleBase} <em>{labels.sectionTitleEm}</em>
    </h2>

    <!-- Magazine layout: 12 cols -->
    <div class="grid grid-cols-12 gap-x-6 gap-y-12">

      <!-- Pull-quote lead: takes 8 cols, offset 1 -->
      <div class="col-span-12 md:col-span-8 md:col-start-1 relative">
        <div class="relative">
          <span class="absolute -top-6 -left-2 md:-left-8 font-serif text-[8rem] leading-none text-accent-500/25 dark:text-accent-400/20 select-none pointer-events-none" aria-hidden="true" style="font-variation-settings: 'opsz' 144;">"</span>

          <p class="editorial-lead relative z-10 mb-8">
            {bioLead}
          </p>

          <p class="text-ink-700 dark:text-white/70 text-base md:text-lg leading-relaxed max-w-2xl">
            {bioBody}
          </p>

          <div class="mt-10 pt-6 border-t border-ink-300/40 dark:border-white/10 max-w-2xl">
            <p class="meta-label mb-2">Postilla</p>
            <p class="text-ink-500 dark:text-white/55 text-sm md:text-base leading-relaxed italic font-serif">
              {bioTail}
            </p>
          </div>
        </div>
      </div>

      <!-- Sidebar: 4 cols, right side -->
      <aside class="col-span-12 md:col-span-4 md:col-start-9 md:pl-6 md:border-l md:border-ink-300/40 md:dark:border-white/10 md:sticky md:top-28 self-start">
        <dl class="space-y-7">
          <div>
            <dt class="meta-label mb-1.5">/ {labels.position}</dt>
            <dd class="text-ink-900 dark:text-white text-sm md:text-base leading-snug">{profile.location}</dd>
          </div>

          <div>
            <dt class="meta-label mb-1.5">/ {labels.languages}</dt>
            <dd>
              <ul class="space-y-1.5">
                {profile.languages.map(lang => {
                  const key = lang.split(' ')[0];
                  const flag = flagMap[key] ?? '';
                  return (
                    <li class="flex items-baseline gap-2 text-ink-900 dark:text-white/90 text-sm md:text-base">
                      <span class="text-base leading-none">{flag}</span>
                      <span>{lang}</span>
                    </li>
                  );
                })}
              </ul>
            </dd>
          </div>

          <div>
            <dt class="meta-label mb-1.5">/ {labels.personality}</dt>
            <dd class="text-ink-900 dark:text-white text-sm md:text-base">
              <span class="meta-mono text-accent-600 dark:text-accent-400 font-medium">{profile.mbti}</span>
              <span class="text-ink-500 dark:text-white/50 text-xs ml-1">— MBTI</span>
            </dd>
          </div>

          <div>
            <dt class="meta-label mb-1.5">/ {labels.availability}</dt>
            <dd class="flex items-center gap-2 text-ink-900 dark:text-white text-sm md:text-base">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent-500 status-pulse"></span>
              <span>{profile.availability}</span>
            </dd>
          </div>
        </dl>
      </aside>

    </div>
  </div>
</section>

<style>
  .status-pulse {
    box-shadow: 0 0 0 0 rgba(217, 119, 87, 0.6);
    animation: statusPulse 2.2s ease-in-out infinite;
  }
  @keyframes statusPulse {
    0%   { box-shadow: 0 0 0 0 rgba(217, 119, 87, 0.6); }
    70%  { box-shadow: 0 0 0 8px rgba(217, 119, 87, 0); }
    100% { box-shadow: 0 0 0 0 rgba(217, 119, 87, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .status-pulse { animation: none; }
  }
</style>
