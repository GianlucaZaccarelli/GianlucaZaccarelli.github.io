---
import { profile, socialLinks } from '../data/profile';
import { experience } from '../data/experience';
import { education } from '../data/education';
import { skills } from '../data/skills';
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{profile.name} — Curriculum Vitae</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 10pt;
      color: #1a1a1a;
      background: #fff;
      line-height: 1.5;
    }

    /* A4 page */
    .page {
      width: 210mm;
      min-height: 297mm;
      margin: 0 auto;
      padding: 14mm 16mm 14mm 16mm;
    }

    /* ── HEADER ─────────────────────────────── */
    .cv-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 10px;
      border-bottom: 2px solid #455ce9;
      margin-bottom: 14px;
    }
    .cv-header h1 {
      font-size: 22pt;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .cv-header .title {
      font-size: 11pt;
      color: #455ce9;
      font-weight: 600;
      margin-top: 2px;
    }
    .cv-header .meta {
      font-size: 8.5pt;
      color: #555;
      margin-top: 4px;
    }
    .contacts {
      text-align: right;
      font-size: 8.5pt;
      color: #444;
      line-height: 1.8;
    }
    .contacts a { color: #455ce9; text-decoration: none; }

    /* ── SECTIONS ───────────────────────────── */
    .section { margin-bottom: 14px; }

    .section-title {
      font-size: 9.5pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #455ce9;
      border-bottom: 1px solid #c7d0f8;
      padding-bottom: 3px;
      margin-bottom: 8px;
    }

    /* ── ABOUT ──────────────────────────────── */
    .about-text {
      font-size: 9.5pt;
      color: #333;
      line-height: 1.6;
    }

    /* ── EXPERIENCE / EDUCATION ─────────────── */
    .entry { margin-bottom: 10px; page-break-inside: avoid; }
    .entry-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .entry-role {
      font-weight: 700;
      font-size: 10pt;
      color: #111;
    }
    .entry-period {
      font-size: 8.5pt;
      color: #666;
      white-space: nowrap;
    }
    .entry-company {
      font-size: 9pt;
      color: #455ce9;
      font-weight: 600;
    }
    .entry-location {
      font-size: 8pt;
      color: #888;
      margin-bottom: 3px;
    }
    .entry-bullets {
      padding-left: 14px;
      margin-top: 3px;
    }
    .entry-bullets li {
      font-size: 9pt;
      color: #333;
      margin-bottom: 1px;
    }
    .entry-desc {
      font-size: 9pt;
      color: #333;
      margin-top: 2px;
    }

    /* ── SKILLS ─────────────────────────────── */
    .skills-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 20px;
    }
    .skill-category { font-weight: 700; font-size: 9pt; color: #111; }
    .skill-items { font-size: 9pt; color: #444; }

    /* ── LANGUAGES ──────────────────────────── */
    .lang-list {
      display: flex;
      gap: 20px;
      font-size: 9.5pt;
      color: #333;
    }

    /* ── PRINT SETTINGS ─────────────────────── */
    @media print {
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .page { margin: 0; padding: 12mm 14mm; width: 100%; }
      a { color: inherit; text-decoration: none; }
    }
  </style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <header class="cv-header">
    <div>
      <h1>{profile.name}</h1>
      <div class="title">{profile.title}</div>
      <div class="meta">{profile.location} &nbsp;·&nbsp; {profile.availability} &nbsp;·&nbsp; MBTI: {profile.mbti}</div>
    </div>
    <div class="contacts">
      <div><a href={`mailto:${profile.email}`}>{profile.email}</a></div>
      {socialLinks.filter(l => l.icon !== 'mail').map(l => (
        <div><a href={l.href}>{l.label}: {l.href.replace('https://', '')}</a></div>
      ))}
    </div>
  </header>

  <!-- ABOUT -->
  <section class="section">
    <div class="section-title">Profilo</div>
    <p class="about-text">{profile.bio}</p>
  </section>

  <!-- EXPERIENCE -->
  <section class="section">
    <div class="section-title">Esperienza Lavorativa</div>
    {experience.map(exp => (
      <div class="entry">
        <div class="entry-header">
          <span class="entry-role">{exp.role}</span>
          <span class="entry-period">{exp.period}</span>
        </div>
        <div class="entry-company">{exp.company}</div>
        <div class="entry-location">{exp.location}</div>
        <ul class="entry-bullets">
          {exp.description.map(d => <li>{d}</li>)}
        </ul>
      </div>
    ))}
  </section>

  <!-- EDUCATION -->
  <section class="section">
    <div class="section-title">Formazione</div>
    {education.map(edu => (
      <div class="entry">
        <div class="entry-header">
          <span class="entry-role">{edu.degree} — {edu.field}</span>
          <span class="entry-period">{edu.year}</span>
        </div>
        <div class="entry-company">{edu.institution}</div>
        <div class="entry-desc">{edu.description}</div>
      </div>
    ))}
  </section>

  <!-- SKILLS -->
  <section class="section">
    <div class="section-title">Competenze Tecniche</div>
    <div class="skills-grid">
      {skills.map(s => (
        <div>
          <span class="skill-category">{s.category}: </span>
          <span class="skill-items">{s.items.join(' · ')}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- LANGUAGES -->
  <section class="section">
    <div class="section-title">Lingue</div>
    <div class="lang-list">
      {profile.languages.map(l => <span>{l}</span>)}
    </div>
  </section>

</div>
</body>
</html>
