---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import LoadingScreen from '../components/LoadingScreen.astro';
import { getProfile, socialLinks } from '../data/profile';
import type { Locale } from '../data/types';
import mainImage from '../assets/MainImage.jpg';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const { locale = 'it' } = Astro.props;

const defaultMeta = locale === 'en'
  ? {
      title: 'Gianluca Zaccarelli - Senior Full-Stack Developer',
      description:
        'Portfolio and curriculum vitae of Gianluca Zaccarelli, Senior Full-Stack Developer with experience in C#, microservices, Docker, and enterprise development.',
    }
  : {
      title: 'Gianluca Zaccarelli - Senior Full-Stack Developer',
      description:
        'Portfolio e curriculum vitae di Gianluca Zaccarelli, Senior Full-Stack Developer con esperienza in C#, microservizi, Docker e sviluppo enterprise.',
    };

const {
  title = defaultMeta.title,
  description = defaultMeta.description,
} = Astro.props;

const profile = getProfile(locale);

const siteUrl = (Astro.site ?? new URL('https://gianlucazaccarelli.github.io')).toString().replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageAsset = await getImage({ src: mainImage, width: 1200, format: 'jpg' });
const ogImage = new URL(ogImageAsset.src, siteUrl).toString();
const ogLocale = locale === 'en' ? 'en_US' : 'it_IT';
const skipLabel = locale === 'en' ? 'Skip to content' : 'Salta al contenuto';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.title,
  email: `mailto:${profile.email}`,
  url: siteUrl,
  image: ogImage,
  address: {
    '@type': 'PostalAddress',
    addressLocality: profile.city,
    addressCountry: profile.country,
  },
  sameAs: socialLinks.filter((l) => l.icon !== 'mail').map((l) => l.href),
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    {
      import.meta.env.PROD && import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
        <script
          is:inline
          defer
          data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
          src="https://plausible.io/js/script.js"
        />
      )
    }

    <title>{title}</title>

    <!-- Apply dark class before paint to avoid flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <a href="#about" class="skip-to-content">{skipLabel}</a>
    <LoadingScreen />
    <slot />
  </body>
</html>
